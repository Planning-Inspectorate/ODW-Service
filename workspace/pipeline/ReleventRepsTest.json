{
	"name": "ReleventRepsTest",
	"properties": {
		"activities": [
			{
				"name": "NSIP_Relevant_Representation",
				"description": "SQL query to get Relevant Representation data to be linked to existing NSIP data",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [
					{
						"name": "Source",
						"value": "."
					},
					{
						"name": "Destination",
						"value": "odw-raw/@{concat('Horizon', '/', formatDateTime(utcnow(), 'yyyy-MM-dd'))}/@{'NSIPReleventRepresentation.csv'}"
					}
				],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": "SELECT\nC.CaseReference\n,C.CaseUniqueId\n,C2.[ID] AS ContactID\n,C2.[OrganisationName]\n,C2.[JobTitle]\n,C2.[FullName]\n,C2.[PhoneNumber]\n,C2.[EmailAddress]\n,C2.[BuildingNumber]\n,C2.[Street]\n,C2.[Town]\n,C2.[County]\n,C2.[Country]\n,C2.[Postcode]\n,RR.[ID] AS RelevantRepID\n,RR.[AttendPrelimMeeting]\n,RR.[DateReceived]\n-- Replacing ',' and new line characters with spaces\n,REPLACE(REPLACE(REPLACE(CAST(RR.[Notes] AS NVarchar(MAX)),',',' '), CHAR(13), ' '), CHAR(10), ' ') AS Notes\n,RR.[AgentContactId]\n,RR.[RepresentAtCompAcqHearing]\n,RR.[RepresentAtIssueHearing]\n,RR.[RepresentAtOpenFloorHearing]\n,REPLACE(REPLACE(REPLACE(CAST(RR.[RepresentationOriginal] AS NVarchar(MAX)),',',';'), CHAR(13), ''), CHAR(10), '') AS RepresentationOriginal\n,REPLACE(REPLACE(REPLACE(CAST(RR.[RepresentationRedacted] AS NVarchar(MAX)),',',';'), CHAR(13), ''), CHAR(10), '') AS RepresentationRedacted\n,RR.[SubmitLaterReps]\n,RR.[SubmitLaterReps]\n,RR.[WebReference]\n,RRS.[Name] AS RelevantRepStatus\n,RRL.[OwnerOrOccupier]\n,RRL.[PowerToSell]\n,RRL.[EntitledToClaim]\n,RRL.[Other]\n,RRL.[DescriptionIfOther]\n,RRB.[Name] AS RelRepOnBehalfOf\n,RRO.[Name] AS RelRepOrganisation\n,COM.[Name] AS PreferredContactMethod\nFROM [otcs].[dbo].[Horizon_RelevantRepresentation] RR\nLEFT JOIN [otcs].[dbo].[Horizon_CaseReference] C ON RR.CaseId = C.CaseNodeId\nLEFT JOIN [otcs].[dbo].[Horizon_RelevantRepContact] C2 ON RR.ContactId = C2.ID\nLEFT JOIN [otcs].[dbo].[Horizon_TypeOfRelevantRepState] RRS ON RR.RepresentationStateId = RRS.ID\nLEFT JOIN [otcs].[dbo].[Horizon_RelevantRepInterestInLand] RRL ON RR.InterestInLandId = RRL.ID\nLEFT JOIN [otcs].[dbo].[Horizon_TypeOfRelRepOnBehalfOf] RRB ON RR.OnBehalfOfId = RRB.ID\nLEFT JOIN [otcs].[dbo].[Horizon_TypeOfRelRepOrganisation] RRO ON RR.OrganisationTypeId = RRO.ID\nLEFT JOIN [otcs].[dbo].[Horizon_TypeOfCommunicationPreference] COM ON RR.PreferredContactMethodId = COM.ID",
						"queryTimeout": "02:00:00",
						"isolationLevel": "ReadCommitted",
						"partitionOption": "None"
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
