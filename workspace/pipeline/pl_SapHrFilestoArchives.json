{
	"name": "pl_SapHrFilestoArchives",
	"properties": {
		"activities": [
			{
				"name": "Copy_SapHrFilestoArchives",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "BinarySource",
						"storeSettings": {
							"type": "AzureFileStorageReadSettings",
							"recursive": true,
							"wildcardFolderPath": {
								"value": "@concat(pipeline().parameters.FolderPath,'/',pipeline().parameters.FileLoad_Type)",
								"type": "Expression"
							},
							"wildcardFileName": "*.xlsx",
							"deleteFilesAfterCompletion": false
						},
						"formatSettings": {
							"type": "BinaryReadSettings"
						}
					},
					"sink": {
						"type": "BinarySink",
						"storeSettings": {
							"type": "AzureFileStorageWriteSettings",
							"copyBehavior": "PreserveHierarchy"
						}
					},
					"enableStaging": false
				},
				"inputs": [
					{
						"referenceName": "Ds_HrSapCopyAFSource",
						"type": "DatasetReference",
						"parameters": {
							"FileLoadType": {
								"value": "@pipeline().parameters.FileLoad_Type",
								"type": "Expression"
							},
							"FolderPath": {
								"value": "@pipeline().parameters.FolderPath",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "Ds_HrSapBinaryDest",
						"type": "DatasetReference",
						"parameters": {
							"FolderPath": {
								"value": "@pipeline().parameters.FolderPath",
								"type": "Expression"
							},
							"FileLoadType": {
								"value": "@pipeline().parameters.FileLoad_Type",
								"type": "Expression"
							}
						}
					}
				]
			}
		],
		"parameters": {
			"FileLoad_Type": {
				"type": "string"
			},
			"FolderPath": {
				"type": "string"
			}
		},
		"folder": {
			"name": "SapHR/pln_SAPHR_SharepointData"
		},
		"annotations": []
	}
}