		"cells": [
			{
				"cell_type": "code",
				"source": [
					"# Define the database and prefix\n",
					"database_name = \"odw_standardised_db\"\n",
					"prefix = \"ZZZ_\"\n",
					"\n",
					"# Get all tables in the database\n",
					"tables_df = spark.sql(f\"SHOW TABLES IN {database_name}\")\n",
					"\n",
					"# Filter tables that start with the prefix\n",
					"tables_to_drop = tables_df.filter(tables_df[\"tableName\"].startswith(prefix)).select(\"tableName\").rdd.flatMap(lambda x: x).collect()\n",
					"\n",
					"# Drop each table\n",
					"for table in tables_to_drop:\n",
					"    full_table_name = f\"{database_name}.{table}\"\n",
					"    print(f\"Dropping table: {full_table_name}\")\n",
					"    spark.sql(f\"DROP TABLE {full_table_name}\")\n",
					"\n",
					"print(\"All tables starting with 'ZZZ_' have been dropped.\")\n",
					""
				],
				"execution_count": 1
			}
		]
	}
