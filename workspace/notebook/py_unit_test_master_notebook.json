				"source": [
					"from threading import Thread\n",
					"from queue import Queue\n",
					"from notebookutils import mssparkutils\n",
					"\n",
					"def worker(q):\n",
					"    while not q.empty():\n",
					"        task = q.get()\n",
					"        try:\n",
					"            # Either run a notebook, or call some other function here\n",
					"            mssparkutils.notebook.run(task[\"path\"], 1800, task[\"params\"])\n",
					"        finally:\n",
					"            q.task_done()\n",
					"\n",
					"tasks = [\n",
					"    {\"path\": \"utils/unit-tests/py_unit_tests_appeal_document\": {\"param1\": \"foo\"}},\n",
					"    {\"path\": \"utils/unit-tests/py_unit_tests_has_appeals\": {\"param1\": \"bar\"}},\n",
					"    {\"path\": \"utils/unit-tests/py_unit_tests_appeals_events\"{}}\n",
					"]\n",
					"\n",
					"q = Queue()\n",
					"for t in tasks:\n",
					"    q.put(t)\n",
					"\n",
					"worker_count = 2\n",
					"for _ in range(worker_count):\n",
					"    t = Thread(target=worker, args=(q,))\n",
					"    t.start()\n",
					"\n",
					"q.join()\n",
					""
				],
				"execution_count": 13
			},
